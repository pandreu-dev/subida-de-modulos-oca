<odoo>
    <record id="module_category_oca_installer" model="ir.module.category">
        <field name="name">OCA Installer</field>
        <field name="description">Gestion visual de repositorios y addons OCA</field>
        <field name="sequence">30</field>
    </record>

    <record id="privilege_oca_installer" model="res.groups.privilege">
        <field name="name">OCA Installer</field>
        <field name="category_id" ref="instalador_modulos_github_v19.module_category_oca_installer"/>
        <field name="sequence">10</field>
    </record>

    <record id="group_oca_installer_user" model="res.groups">
        <field name="name">OCA Installer User</field>
        <field name="privilege_id" ref="instalador_modulos_github_v19.privilege_oca_installer"/>
        <field name="sequence">10</field>
        <field name="implied_ids" eval="[(4, ref('base.group_user'))]"/>
    </record>
</odoo>
